# ═══════════════════════════════════════════
# ShieldGuard — .gitignore
# ═══════════════════════════════════════════

# Python
__pycache__/
*.pyc
*.pyo

# Virtual environments
.venv/
venv/

# Streamlit secrets
.streamlit/

# OS files
.DS_Store
Thumbs.db

# Data — only track the production dataset
data/archive/
data/raw/
data/scam_library/
*.db

# HuggingFace model cache
.hf_cache/

# Jupyter
.ipynb_checkpoints/

# IDE / tool config
.codex/
.qodo/
.sixth/
.devcontainer/

# Backend
backend/.env
backend/package-lock.json

# Frontend
frontend/node_modules/
frontend/dist/
frontend/package-lock.json

# Reports (never push unless explicitly asked)
Report/
explanation.md
reportstructure.md

# Legacy
app/supabase_schema.sql
